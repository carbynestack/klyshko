# Client manifest file

loader.entrypoint = "file:{{ gramine.libos }}"
libos.entrypoint = "/client"

loader.log_level = "{{ log_level }}"

loader.env.LD_LIBRARY_PATH = "/lib:/lib2:/usr/local/lib:{{ arch_libdir }}:/usr{{ arch_libdir }}"
loader.env.LC_ALL = "C"

loader.env.RA_TLS_CLIENT_INSIDE_SGX = "1"

loader.insecure__use_cmdline_argv = true
loader.insecure__use_host_env = true
sys.enable_sigterm_injection = true
fs.mounts = [
  { path = "/lib", uri = "file:{{ gramine.runtimedir() }}" },
  { path = "/usr/local/lib", uri = "file:/usr/local/lib" },
  { path = "{{ arch_libdir }}", uri = "file:{{ arch_libdir }}" },
  { path = "/usr{{ arch_libdir }}", uri = "file:/usr{{ arch_libdir }}" },
  { path = "/etc", uri = "file:/etc" },
  { path = "/server", uri = "file:server" },
  { path = "/client", uri = "file:client" },
  { type = "encrypted", path = "/Player-Data/", uri="file:Player-Data/", key_name = "_sgx_mrenclave"},
  { path = "/lib2/", uri="file:/lib/x86_64-linux-gnu/"},
  { path = "/Fake-Offline.x", uri="file:Fake-Offline.x"},
  { path = "/bin/bash", uri = "file:/bin/bash" },
  { path = "/etc/bash.bashrc", uri = "file:/etc/bash.bashrc" },
  { path = "/etc/profile", uri = "file:/etc/profile" },
  { path = "/bin/cp", uri = "file:/bin/cp" },
  { path = "/kii", uri = "file:/kii/"}

]

sys.enable_extra_runtime_domain_names_conf = true
sgx.remote_attestation = "dcap"
sgx.debug = true
sgx.edmm_enable = {{ 'true' if env.get('EDMM', '0') == '1' else 'false' }}
sgx.enclave_size = "512M"
sgx.max_threads = {{ '1' if env.get('EDMM', '0') == '1' else '4' }}

sgx.trusted_files = [
  "file:{{ gramine.libos }}",
  "file:client",
  "file:{{ gramine.runtimedir() }}/",
  "file:/usr/local/lib/",
  "file:{{ arch_libdir }}/",
  "file:/usr{{ arch_libdir }}/",
  "file:ssl/ca.crt",
  "file:Fake-Offline.x",
  "file:/lib/x86_64-linux-gnu/",
  # Add trusted files for bash
  "file:/bin/bash",
  "file:/etc/bash.bashrc",
  "file:/etc/profile",
  "file:/bin/cp",
  "file:/kii/"

]

sgx.allowed_files = [
  "file:/etc/nsswitch.conf",
  "file:/etc/host.conf",
  "file:/etc/ethers",
  "file:/etc/hosts",
  "file:/etc/group",
  "file:/etc/passwd",
  "file:/etc/gai.conf",
  "file:/etc/ssl/certs/ca-certificates.crt",
  "file:/etc/sgx_default_qcnl.conf",
  "file:./Player-Data",
  "file:/lib/x86_64-linux-gnu",
  "file:/bin/bash",
  "file:/etc/bash.bashrc",
  "file:/etc/profile",
  "file:/bin/cp",
  "file:/kii/",
  "file:/etc/kii/params/prime",
  "file:/etc/kii/secret-params/mac_key_share_p",
  "file:/etc/kii/secret-params/mac_key_share_2"
]
